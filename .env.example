# Neon Postgres connection string (Vercel may also expose POSTGRES_URL)
DATABASE_URL=postgres://user:password@host:5432/custardsquare

# Payload CMS secret — use a long random string (32+ chars)
# Required on Vercel for Production + Preview (build and runtime)
PAYLOAD_SECRET=your-secret-here

# Public site URL — production canonical domain (used for SEO, RSS, sitemap)
# Local: http://localhost:3000
# Vercel Production only: https://custardsq.app
# Preview deploys auto-use VERCEL_URL (e.g. custardsquare-exe-git-main-....vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Blob storage token (from Vercel dashboard after adding Blob store)
BLOB_READ_WRITE_TOKEN=
